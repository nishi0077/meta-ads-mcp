# === Meta Ads MCP Server Configuration ===

# Auth type: "oauth" (recommended) or "system_user"
META_AUTH_TYPE=oauth

# OAuth settings (required for oauth auth type)
# Get these from: https://developers.facebook.com/ → Your App → Settings → Basic
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# System User token (required for system_user auth type)
META_ACCESS_TOKEN=EAAxxxx...

# Default ad account ID (optional, some tools use it as default)
META_AD_ACCOUNT_ID=act_xxxxxxxxxxxxx

# API version (optional, defaults to v24.0)
META_API_VERSION=v24.0
